# Local API (artifacts/api-server): copy to `.env` or `.env.local` at the **repository root**
# so Drizzle and the API see the same vars. Restart `pnpm run dev` / api-server after editing.

# Postgres (local or tunnel URL)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DBNAME

# Public URL for OAuth redirects and email links (local UI is usually http://localhost:5173)
APP_URL=http://localhost:5173

# Resend — required for signup verification, password reset, support mail, and scheduled reminders
RESEND_API_KEY=

# Soniox — required for live transcription (/api/transcription/token)
SONIOX_API_KEY=
# Aliases: SONIOX_STT_API_KEY, SONIOX_KEY, SONIOX_API_TOKEN (case-insensitive env names OK)

# *-libre machine translation: LibreTranslate only (free public HTTPS endpoints when LIBRETRANSLATE_URL is unset).
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=
