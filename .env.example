# Local API (artifacts/api-server): copy to `.env` or `.env.local` at the **repository root**
# so Drizzle and the API see the same vars. Restart `pnpm run dev` / api-server after editing.

# Postgres (local or tunnel URL)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DBNAME

# Public URL for OAuth redirects and email links (local UI is usually http://localhost:5173)
APP_URL=http://localhost:5173

# Resend — required for signup verification, password reset, support mail, and scheduled reminders
RESEND_API_KEY=

# Soniox — required for live transcription (/api/transcription/token)
SONIOX_API_KEY=
# Aliases: SONIOX_STT_API_KEY, SONIOX_KEY, SONIOX_API_TOKEN (case-insensitive env names OK)

# Basic / Professional / trial-libre translation (no OpenAI):
# — Free default: LibreTranslate public mirrors (failover), then MyMemory if all fail (tiny per-request + daily limits).
# — For production volume/stability: self-host LibreTranslate, or use a cloud free tier (e.g. Azure Translator F0).
# — Optional: GOOGLE_TRANSLATE_API_KEY tries Google Cloud first when set (paid).
GOOGLE_TRANSLATE_API_KEY=
# Optional: pin one LibreTranslate base URL (e.g. self-hosted). If unset, free public hosts are tried in order.
LIBRETRANSLATE_URL=
# Optional: API key only if your LibreTranslate instance requires it
LIBRETRANSLATE_API_KEY=
