{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./resolve-db-url": {
      "types": "./src/resolve-db-url.ts",
      "default": "./src/resolve-db-url.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "push": "node ./run-drizzle-kit.cjs push",
    "push-force": "node ./run-drizzle-kit.cjs push --force"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0"
  }
}
