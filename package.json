{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "dev": "pnpm --filter @apps/api dev",
    "start": "pnpm --filter @apps/api start",
    "build:api-server": "pnpm --filter @workspace/api-server run build",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:push:force": "pnpm --filter @workspace/db run push-force",
    "db:push:railway": "bash scripts/railway-db-push.sh",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "validate:package-json": "node scripts/validate-all-package-json.mjs"
  },
  "private": true,
  "dependencies": {
    "stripe": "^21.0.1",
    "stripe-replit-sync": "^1.0.0"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "pnpm": {
    "overrides": {
      "cookie-signature": "1.2.2",
      "path-to-regexp": "8.4.0",
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4"
    }
  }
}
