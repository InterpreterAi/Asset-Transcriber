{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
 "scripts": {
  "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
  "build": "pnpm --filter ./artifacts/api-server run build"
  "start": "node artifacts/api-server/dist/index.js",
  "typecheck": "tsc -p tsconfig.json --noEmit"
},
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "stripe": "^21.0.1",
    "stripe-replit-sync": "^1.0.0"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": "8.4.0",
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4"
    }
  }
}
