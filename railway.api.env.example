# Paste into Railway → the service that runs THIS API (the Docker/web service), NOT the Postgres service.
# Variables tab → New Variable → choose "Variable Reference" and pick Postgres → DATABASE_URL,
# or paste the line below using your database service’s exact name from the project canvas.
#
# Common reference (default Postgres plugin name is "Postgres"):
DATABASE_URL=${{Postgres.DATABASE_URL}}
#
# If your DB service is named differently, match it exactly, e.g.:
# DATABASE_URL=${{PostgreSQL.DATABASE_URL}}
#
# Optional (private networking / some templates):
# DATABASE_PRIVATE_URL=${{Postgres.DATABASE_PRIVATE_URL}}

# ── Live transcription (Soniox) — same API service as DATABASE_URL above ──
SONIOX_API_KEY=
# Aliases: SONIOX_STT_API_KEY, SONIOX_KEY, SONIOX_API_TOKEN (case-insensitive names OK)

# ── Translation / terminology (OpenAI) ──
OPENAI_API_KEY=

# ── Transactional email (Resend) — server only, never exposed to the client ──
# RESEND_API_KEY=

# ── Google OAuth + sessions (if missing, /debug/ai-env lists them under missingInProcessEnv) ──
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# SESSION_SECRET=
# (or NEXTAUTH_SECRET)
