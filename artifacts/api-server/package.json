{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "dev:watch": "NODE_ENV=development tsx watch src/index.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "glossary:generate": "node ./scripts/generate-interpreter-glossaries.mjs",
    "glossary:verify": "tsx ./scripts/verify-interpreter-glossary.ts",
    "email:send-account-active-reminder-now": "tsx ./src/lib/send-account-active-reminder-now.ts",
    "email:send-translation-architecture-update-now": "tsx ./src/lib/send-translation-architecture-update-now.ts",
    "email:send-stability-baseline-update-now": "tsx ./src/lib/send-stability-baseline-update-now.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@workspace/api-zod": "workspace:*",
    "@workspace/app-timezone": "workspace:*",
    "@workspace/db": "workspace:*",
    "axios": "^1.14.0",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^16.6.1",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "openai": "^6.33.0",
    "pino": "^9",
    "pino-http": "^10",
    "qrcode": "^1.5.4",
    "resend": "^6.9.4",
    "scrypt-js": "^3.0.1",
    "speakeasy": "^2.0.0",
    "sql-template-strings": "^2.2.2"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "catalog:",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
